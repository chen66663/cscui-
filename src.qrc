<RCC>
    <!-- Stable public asset prefix. QML and C++ consumers use qrc:/cscui/. -->
    <qresource prefix="/cscui">
        <file>fonts/icon.ico</file>
        <file>fonts/fontawesome-free-6.7.2-desktop/otfs/Font Awesome 6 Free-Solid-900.otf</file>
        <file>fonts/pic/avatar.png</file>
        <file>fonts/pic/01.jpg</file>
        <file>fonts/pic/02.jpg</file>
        <file>fonts/loader.gif</file>
    </qresource>
</RCC>
